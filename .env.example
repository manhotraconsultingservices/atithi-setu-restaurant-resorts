# ═══════════════════════════════════════════════════════════════════════════════
# Atithi-Setu — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── JWT ────────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=
PGHOST=db
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=main_database
PGSSL=false

# ══════════════════════════════════════════════════════════════════════════════
# WHATSAPP — Meta Cloud API (Business Messaging)
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO SET UP:
#   1. Go to https://developers.facebook.com/ and create a Business App.
#   2. Add the "WhatsApp" product to your app.
#   3. In WhatsApp > Getting Started, copy:
#        - Temporary / permanent access token  → META_WA_ACCESS_TOKEN
#        - Phone Number ID                      → META_WA_PHONE_NUMBER_ID
#        - WhatsApp Business Account (WABA) ID  → META_WA_BUSINESS_ACCOUNT_ID
#   4. For production use a PERMANENT token via:
#        Business Settings → System Users → Add → Generate Token (whatsapp_business_messaging scope)
#   5. Webhook setup (delivery receipts & incoming messages):
#        a. Callback URL  →  https://your-domain/api/webhooks/whatsapp
#        b. Verify Token  →  paste the same string below as META_WA_VERIFY_TOKEN
#        c. Subscribe to: messages, message_deliveries, message_reads
#
# PHONE FORMAT: Recipients must be in E.164 (e.g. +919876543210).
#   The app auto-converts 10-digit Indian mobiles to +91XXXXXXXXXX.
#
# NOTE: Business-initiated messages outside a 24-hour customer conversation
#   window require approved Message Templates registered in Meta Business Manager.

META_WA_ACCESS_TOKEN=          # Permanent System User token
META_WA_PHONE_NUMBER_ID=       # Numeric ID shown in Meta Developer console
META_WA_BUSINESS_ACCOUNT_ID=   # WABA ID (optional — for account-level operations)
META_WA_VERIFY_TOKEN=          # Any secret string you choose for webhook verification

# ══════════════════════════════════════════════════════════════════════════════
# SMS — Twilio
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO SET UP:
#   1. Sign up at https://www.twilio.com/
#   2. From the Console Dashboard copy Account SID and Auth Token.
#   3. Buy or use a trial SMS-capable number → set as TWILIO_PHONE_NUMBER.
#
# PHONE FORMAT: E.164 required (e.g. +14155551234).

TWILIO_ACCOUNT_SID=            # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=             # Your Twilio auth token
TWILIO_PHONE_NUMBER=           # Your Twilio SMS number in E.164, e.g. +14155551234

# ══════════════════════════════════════════════════════════════════════════════
# EMAIL — SMTP / Nodemailer
# ══════════════════════════════════════════════════════════════════════════════
#
# HOW TO SET UP (Gmail):
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail" → paste as SMTP_PASS.
#   4. Use smtp.gmail.com:587 with SMTP_SECURE=false (STARTTLS).
#
# Other providers:
#   Outlook/Hotmail : smtp-mail.outlook.com  port 587  secure false
#   Yahoo           : smtp.mail.yahoo.com     port 465  secure true
#   Custom SMTP     : use your hosting provider's settings

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false              # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER=                     # Your email address
SMTP_PASS=                     # App Password (NOT your regular login password)
SMTP_FROM=                     # e.g. "Atithi-Setu <no-reply@example.com>"
